# WeatherRouter Configuration
# Copy this file to .env and adjust values as needed.

# Default routing provider: "osrm" or "google"
ROUTING_PROVIDER=osrm

# Google Maps API key (required only when ROUTING_PROVIDER=google)
# Get yours at https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# OSRM public server (no API key required)
OSRM_BASE_URL=https://router.project-osrm.org

# Nominatim geocoding server (no API key required)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Server bind address and port
HOST=0.0.0.0
PORT=8000
