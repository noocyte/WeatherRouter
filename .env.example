# ──────────────────────────────────────────────────────────────
# WeatherRouter — Configuration
# Copy this file to .env and adjust values as needed.
# All settings have sensible defaults so the app runs out of the box.
# ──────────────────────────────────────────────────────────────

# ── Routing ───────────────────────────────────────────────────

# Default routing provider ("osrm" or "google")
ROUTING_PROVIDER=osrm

# Google Maps Directions API key (required only for the "google" provider)
# Get one at https://console.cloud.google.com/apis/credentials
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# OSRM server URL (default: public demo server)
OSRM_BASE_URL=https://router.project-osrm.org

# ── Weather ───────────────────────────────────────────────────

# Weather provider ("open_meteo" or "yr")
WEATHER_PROVIDER=open_meteo

# Open-Meteo API URL (default: public server, free, no API key)
OPEN_METEO_BASE_URL=https://api.open-meteo.com

# MET Norway (Yr.no) contact info — REQUIRED by their TOS when using "yr" provider.
# Must be an app URL or email so MET Norway can reach you if there are problems.
# See: https://developer.yr.no/doc/TermsOfService/
# YR_CONTACT_INFO=github.com/youruser/weatherrouter contact@example.com

# ── Geocoding ─────────────────────────────────────────────────

# Nominatim server URL (default: public OSM server)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# ── Server ────────────────────────────────────────────────────

# Host address the server binds to
HOST=0.0.0.0

# Port the server listens on
PORT=8000
